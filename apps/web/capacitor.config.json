{
  "appId": "com.accounting.personal",
  "appName": "个人记账助手",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "server": {
    "cleartext": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 3000,
      "backgroundColor": "#1890ff",
      "androidSplashResourceName": "splash"
    }
